# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=financial_pdf_reader

# ── ChromaDB ──────────────────────────────────────────────────────────────────
LOCAL_CHROMADB_PATH=./data/chromadb

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256

# ── LLM ───────────────────────────────────────────────────────────────────────
# Swap to whichever provider you use
MISTRAL_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/raw_pdfs
EXTRACTED_DIR=./data/extracted
REPORTS_DIR=./data/reports
