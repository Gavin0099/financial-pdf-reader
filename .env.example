# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=financial_pdf_reader

# ── ChromaDB ──────────────────────────────────────────────────────────────────
LOCAL_CHROMADB_PATH=./data/chromadb

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Taiwan Data Source ────────────────────────────────────────────────────────
# FinMind 免費版不需要 token，有 token 可提高 rate limit
# 申請：https://finmindtrade.com
FINMIND_TOKEN=

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/raw_pdfs
EXTRACTED_DIR=./data/extracted
REPORTS_DIR=./data/reports
