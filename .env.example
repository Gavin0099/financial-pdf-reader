# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/financial_pdf_reader
MONGODB_DB_NAME=financial_pdf_reader

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Taiwan Data Source ────────────────────────────────────────────────────────
# FinMind 免費版不需要 token，有 token 可提高 rate limit
# 申請：https://finmindtrade.com
FINMIND_TOKEN=

# ── File storage（Railway/production 建議用 /tmp）────────────────────────────
UPLOAD_DIR=/tmp/raw_pdfs
EXTRACTED_DIR=/tmp/extracted
REPORTS_DIR=/tmp/reports
